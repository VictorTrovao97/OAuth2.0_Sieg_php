{
    "name": "sieg/auth",
    "description": "SDK de autenticação OAuth 2.0 da SIEG para sistemas emissores de nota fiscal (PHP)",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^2.0 || ^3.0"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "SiegAuth\\": "src/SiegAuth/"
        }
    },
    "minimum-stability": "stable"
}
